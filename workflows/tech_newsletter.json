    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst then = new Date(now.getFullYear(), now.getMonth(), now.getDate() - 3);\n\nconst fmt = date => date.toISOString().split(\"T\")[0];\n\nreturn [{ \n  json: { \n    startDate: fmt(then),\n    endDate: fmt(now)\n  } \n}];"
      },
