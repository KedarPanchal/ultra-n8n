    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a news agent whose purpose is to search for the latest tech/computer science news across a variety of popular channels and output them. Look for the top 7 to 10 stories online. Try to find 10 stories. These articles should be diverse in content; don't have all of the found news be solely covering AI or cryptocurrency, for example. The news should be focused on tech and computer science, and shouldn't be as focused on other disciplines unless there is a direct relation to tech and computer science.\n\nOnly search for news that has been published between {{ $json.startDate }} to {{ $json.endDate }} (the dates are in yyyy-mm-dd format).\n\nYour output should be in JSON format. It should be a single field called results, which contains list of JSON objects. Each object in this list should have the following fields:\n- title: The title of the news you found\n- content: Your summary of the news content. Cover important points in paragraph form in sufficient detail, but avoid repeating yourself. Target for at least two to four detailed paragraphs of summary content. These summaries should have a journalistic tone and should focus on convering information instead of referencing the article or qualities of the article.\n- url: The URL to the article or piece of news covering this information.",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "Summarize only based on information you searched for using the provided tool calls. Never provide information from your own knowledge.\nYou must utilize tool calls to find your information. When calling the HTTP request tool to search, never include double quotes in your searches."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        416,
        0
      ],
      "id": "8183bf06-e574-4e80-9998-1bc3619a2808",
      "name": "AI Agent",
      "retryOnFail": true
    },
    {
      "parameters": {
        "jsonSchemaExample": "{\n  \"results\": [\n    {\n      \"title\": \"New Programming Language Accelerates Parallel Computing\",\n      \"content\": \"A new programming language inspired by Python has allowed for quick and easy programming of CUDA GPUs, accelerating the field of parallel computing\",\n      \"url\": \"https://example.com/article\"\n    },\n    {\n      \"title\": \"Quantum Computing Breakthrough Allows for Faster Prime Factorization\",\n      \"content\": \"A new quantum computer architecture developed by Google has allowed for faster performance in prime factorizing large numbers.\",\n      \"url\": \"https://technews.com/news\"\n    }\n  ]\n}"
      },
