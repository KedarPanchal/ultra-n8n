    {
      "parameters": {
        "jsCode": "// Fetch the OpenGraph image for a given URL\nconst preview = async (url) => {\n  const defaultURL = \"https://placehold.co/600x400/grey/grey\";\n  const response = await fetch(url);\n  // If response failed, just yield preview image url\n  if (!response) return defaultURL;\n  // Attempt to extract og:image from requested HTML\n};\n\n// Convert an item to the RSS feed content\nconst makeItem = item => `\n    <item>\n      <title>${item.title}</title>\n      <link>${item.url}</link>\n      <description>${item.content}</description>\n      <guid>${item.url}</guid>\n    </item>\n`;\n\n// Convert each item to RSS feed content\nconst rssContent = [];\nfor (const item of $input.first().json.output.results) {\n  rssContent.push(makeItem(item));\n}\n\n// Create the final RSS feed\nconst rssFeed = `\n<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<rss version=\"2.0\">\n  <channel>\n    <title>Kedar's Tech Feed</title>\n    <description>Kedar's Daily Tech News Feed</description>\n${rssContent.join('\\n')}\n  </channel>\n</rss>\n`;\nconst buffer = Buffer.from(rssFeed, \"utf-8\");\n\nreturn [{ \n  json: { xml: rssFeed },\n  binary: {\n    data: await this.helpers.prepareBinaryData(buffer)\n  }\n}];"
      },
